<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- 
      Update this path to your actual shared drive location.
      Example: \\ServerName\SharedFolder\QuizScores.xlsx
      Or a mapped drive: Z:\QuizScores\scores.xlsx
    -->
    <add key="ScoreFilePath" value="\\SharedDrive\QuizScores\QuizScores.xlsx" />
    
    <!-- Quiz title shown in the header -->
    <add key="QuizTitle" value="CATS Team Monthly Quiz" />
    
    <!-- Path to questions JSON file (relative to .exe or absolute) -->
    <add key="QuestionsFilePath" value="questions.json" />
  </appSettings>
</configuration>
